# ============================================================
# AI INFRASTRUCTURE RESEARCH PLATFORM — Environment Variables
# ============================================================
# STEP 1: Copy this file to .env
#         cp .env.example .env
# STEP 2: Fill in your API keys below
# STEP 3: .env is git-ignored — it will never be committed
#
# Source tier legend (matches BACKEND_ARCHITECTURE_ASSESSMENT.md §9.5):
#   Tier 1 — Primary truth (SEC filings, official data)
#   Tier 2 — Finance event/news (Benzinga, structured events)
#   Tier 3 — Structured market aggregators (FMP, Finnhub)
#   Tier 4 — Broad macro/discovery (NewsAPI, FRED)
#   Tier 5 — Fallback only (yfinance, synthetic fills)
# ============================================================

# ------------------------------------------------------------
# PRIMARY AI PROVIDERS
# ------------------------------------------------------------

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# Anthropic / Claude (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini (https://aistudio.google.com/app/apikey)
GOOGLE_API_KEY=AI...

# --- Model overrides (defaults shown) ---
OPENAI_MODEL=gpt-4o
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
GOOGLE_MODEL=gemini-1.5-pro

# ------------------------------------------------------------
# TIER 1 — PRIMARY TRUTH SOURCES
# ------------------------------------------------------------

# SEC API by dv2 / sec-api.io — primary US filings layer
# Get key: https://sec-api.io  (free tier: 100 req/day)
# Used for: 10-K/Q/8-K section extraction, XBRL financials,
#           Form 3/4/5 insider data, real-time filing events
# Stages: 2 (filing index), 3 (XBRL cross-validation),
#         5 (Evidence Librarian), 7 (valuation), 10 (red team)
# NOTE: US-listed companies only. ASX tickers have no equivalent yet.
SEC_API_KEY=

# ------------------------------------------------------------
# TIER 2 — FINANCE EVENT / NEWS LAYER
# ------------------------------------------------------------

# Benzinga — finance-native news, analyst ratings, events, catalysts
# Get key: https://www.benzinga.com/apis/  (paid plans; free trial available)
# Used for: analyst rating changes, earnings catalysts, company news,
#           transcript enrichment (if subscription supports it)
# Stages: 2 (events + ratings), 5 (evidence), 10 (adverse signals)
# NOTE: Demotes FMP/Finnhub news to backfill role.
BENZINGA_API_KEY=

# ------------------------------------------------------------
# TIER 3 — STRUCTURED MARKET DATA AGGREGATORS
# ------------------------------------------------------------

# Financial Modeling Prep — primary quantitative aggregator
# Get key: https://financialmodelingprep.com/developer/docs
# Used for: quotes, fundamentals, estimates, targets, sector financials
# Stages: 2 (core ingest), 6 (sector), 7 (valuation)
FMP_API_KEY=

# Finnhub — secondary quantitative / cross-check source
# Get key: https://finnhub.io  (free tier available)
# Used for: price cross-check, recommendation mix, price targets,
#           earnings calendar, company news (backfill only)
# Stages: 2, 3 (reconciliation vs FMP)
# NOTE: Was missing from .env.example (tracked as ISS-7); now added.
FINNHUB_API_KEY=

# Alpha Vantage — alternative data / supplementary source
# Get key: https://www.alphavantage.co/support/#api-key  (free tier available)
# Used for: supplementary price series, economic indicators
ALPHA_VANTAGE_API_KEY=

# ------------------------------------------------------------
# TIER 4 — MACRO / DISCOVERY / BROAD NEWS
# ------------------------------------------------------------

# NewsAPI — broad news aggregation for macro / policy / regulatory scanning
# Get key: https://newsapi.org  (free tier: 100 req/day, 1-month lookback)
# Used for: Stage 8 macro/political context — export controls, AI regulation,
#           grid/power policy, chip sanctions, geopolitical events
# Stages: 8 (macro + political risk)
# IMPORTANT: Must be used with publisher allowlist and article extraction
#            layer. Without those, adds noise rather than signal.
#            Do NOT wire into Stage 5 evidence until those are in place.
NEWS_API_KEY=

# FRED — Federal Reserve Economic Data (US macro, no key for basic access)
# Get key: https://fred.stlouisfed.org/docs/api/api_key.html  (free, optional)
# Used for: fed funds, CPI, PCE, unemployment, Treasury yields, factor series
# Stages: 8 (macro), 9 (factor engine)
# NOTE: Works without a key for standard series but a key removes rate limits.
FRED_API_KEY=

# ------------------------------------------------------------
# PIPELINE SETTINGS
# ------------------------------------------------------------

# How many stocks to analyse in parallel (keep low to avoid rate limits)
PIPELINE_CONCURRENCY=3

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Output directory for reports
OUTPUT_DIR=./reports

# ------------------------------------------------------------
# STREAMLIT FRONTEND
# ------------------------------------------------------------

# Leave as-is unless you change the port
STREAMLIT_PORT=8501
