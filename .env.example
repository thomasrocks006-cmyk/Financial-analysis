# ============================================================
# AI INFRASTRUCTURE RESEARCH PLATFORM — Environment Variables
# ============================================================
# STEP 1: Copy this file to .env
#         cp .env.example .env
# STEP 2: Fill in your API keys below
# STEP 3: .env is git-ignored — it will never be committed
# ============================================================

# --- PRIMARY AI PROVIDERS ---
# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# Anthropic / Claude (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini (https://aistudio.google.com/app/apikey)
GOOGLE_API_KEY=AI...

# --- OPTIONAL: Model overrides ---
# Default models used if not set:
#   OpenAI  → gpt-4o
#   Anthropic → claude-3-5-sonnet-20241022
#   Google  → gemini-1.5-pro
OPENAI_MODEL=gpt-4o
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
GOOGLE_MODEL=gemini-1.5-pro

# --- OPTIONAL: Data providers ---
# Financial Modeling Prep (https://financialmodelingprep.com/developer/docs)
FMP_API_KEY=

# Alpha Vantage (https://www.alphavantage.co/support/#api-key)
ALPHA_VANTAGE_API_KEY=

# --- PIPELINE SETTINGS ---
# How many stocks to analyse in parallel (keep low to avoid rate limits)
PIPELINE_CONCURRENCY=3

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Output directory for reports
OUTPUT_DIR=./reports

# --- STREAMLIT FRONTEND ---
# Leave as-is unless you change the port
STREAMLIT_PORT=8501
